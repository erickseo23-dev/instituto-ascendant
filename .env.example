# Instituto Ascendant - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ============================================
# SITE CONFIGURATION
# ============================================
VITE_SITE_URL=https://institutoascendant.com
VITE_SITE_NAME=Instituto Ascendant

# ============================================
# GOOGLE ANALYTICS
# ============================================
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# KAJABI INTEGRATION
# ============================================
VITE_KAJABI_API_URL=https://api.kajabi.com/v1
VITE_KAJABI_API_KEY=your_kajabi_api_key_here
VITE_KAJABI_WEBHOOK_SECRET=your_webhook_secret_here

# Kajabi Product IDs
VITE_KAJABI_PRODUCT_MA_L1=product_id_meditacion_ascendente_nivel_1
VITE_KAJABI_PRODUCT_MA_L2=product_id_meditacion_ascendente_nivel_2
VITE_KAJABI_PRODUCT_MA_L3=product_id_meditacion_ascendente_nivel_3
VITE_KAJABI_PRODUCT_CERT_MA=product_id_certificacion_meditacion_ascendente
VITE_KAJABI_PRODUCT_KSH_BASIC=product_id_ks_healing_basico
VITE_KAJABI_PRODUCT_KSH_ADV=product_id_ks_healing_avanzado
VITE_KAJABI_PRODUCT_DART=product_id_dart_renovacion
VITE_KAJABI_PRODUCT_GS=product_id_genetica_sagrada

# ============================================
# SEO & OPEN GRAPH
# ============================================
VITE_DEFAULT_OG_IMAGE=https://institutoascendant.com/og-image.png

# ============================================
# EXTERNAL SERVICES
# ============================================
# Add any other external service keys here
# (Stripe, Mailchimp, etc. if needed in the future)

# ============================================
# DEVELOPMENT
# ============================================
VITE_DEBUG=false
VITE_LOG_LEVEL=info
